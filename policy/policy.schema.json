{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/erc-8004-csp/policy.schema.json",
  "title": "ERC-8004 CSP Consumer Policy",
  "type": "object",
  "required": [
    "version",
    "conformanceLevel",
    "identity",
    "safeFetch",
    "reputation",
    "validation",
    "disclosures"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^0\\.9\\.1$"
    },
    "conformanceLevel": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "identity": {
      "type": "object",
      "required": [
        "requireCurrentRegistrationLink",
        "treatMissingSupportedTrustAsDiscoveryOnly",
        "requireWalletReverificationAfterTransfer",
        "showWalletBindingStatus",
        "showWalletVerificationType"
      ],
      "properties": {
        "requireCurrentRegistrationLink": {"type": "boolean"},
        "treatMissingSupportedTrustAsDiscoveryOnly": {"type": "boolean"},
        "requireWalletReverificationAfterTransfer": {"type": "boolean"},
        "showWalletBindingStatus": {"type": "boolean"},
        "showWalletVerificationType": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "safeFetch": {
      "type": "object",
      "required": [
        "timeoutMs",
        "maxBytes",
        "allowedSchemes",
        "allowedContentTypes",
        "followRedirects",
        "maxRedirects",
        "dataUriPolicy"
      ],
      "properties": {
        "timeoutMs": {"type": "integer", "minimum": 1000, "maximum": 60000},
        "maxBytes": {"type": "integer", "minimum": 1024, "maximum": 104857600},
        "allowedSchemes": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "allowedContentTypes": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "followRedirects": {"type": "boolean"},
        "maxRedirects": {"type": "integer", "minimum": 0, "maximum": 10},
        "ipfsGateways": {
          "type": "array",
          "items": {"type": "string", "format": "uri"}
        },
        "cache": {
          "type": "object",
          "required": ["enabled", "retentionDays", "separateUnanchoredCache"],
          "properties": {
            "enabled": {"type": "boolean"},
            "retentionDays": {"type": "integer", "minimum": 0, "maximum": 3650},
            "separateUnanchoredCache": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "dataUriPolicy": {
          "type": "object",
          "required": ["enabled", "maxBytes", "allowedMediaTypes", "inertOnly"],
          "properties": {
            "enabled": {"type": "boolean"},
            "maxBytes": {"type": "integer", "minimum": 1, "maximum": 10485760},
            "allowedMediaTypes": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            },
            "inertOnly": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "reputation": {
      "type": "object",
      "required": ["weighting", "rateLimits", "display"],
      "properties": {
        "weighting": {
          "type": "object",
          "required": [
            "ageDecayHalfLifeDays",
            "clientAccountAgeWeight",
            "clientProofWeights",
            "stakeWeight",
            "reliabilityWeight"
          ],
          "properties": {
            "ageDecayHalfLifeDays": {"type": "number", "minimum": 1},
            "clientAccountAgeWeight": {"type": "number", "minimum": 0},
            "clientProofWeights": {
              "type": "object",
              "additionalProperties": {"type": "number", "minimum": 0}
            },
            "stakeWeight": {"type": "number", "minimum": 0},
            "reliabilityWeight": {"type": "number", "minimum": 0}
          },
          "additionalProperties": false
        },
        "rateLimits": {
          "type": "object",
          "required": [
            "maxFeedbackPerAgentPerDay",
            "maxResponsesPerFeedback",
            "maxFetchesPerHostPerMinute"
          ],
          "properties": {
            "maxFeedbackPerAgentPerDay": {"type": "integer", "minimum": 1},
            "maxResponsesPerFeedback": {"type": "integer", "minimum": 0},
            "maxFetchesPerHostPerMinute": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": false
        },
        "display": {
          "type": "object",
          "required": [
            "showScalarScore",
            "showConfidence",
            "appendResponsePolicy",
            "distinguishResponseTypes"
          ],
          "properties": {
            "showScalarScore": {"type": "boolean"},
            "showConfidence": {"type": "boolean"},
            "appendResponsePolicy": {
              "type": "string",
              "enum": ["hide", "showAll", "gatedByResponderPolicy"]
            },
            "distinguishResponseTypes": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "requireScopeMethodFreshness",
        "bindToRequestHash",
        "invalidateOnAgentUriChange",
        "showSupersededResponses",
        "finalityRule",
        "validatorPolicy"
      ],
      "properties": {
        "requireScopeMethodFreshness": {"type": "boolean"},
        "bindToRequestHash": {"type": "boolean"},
        "invalidateOnAgentUriChange": {"type": "boolean"},
        "showSupersededResponses": {"type": "boolean"},
        "finalityRule": {
          "type": "string",
          "enum": ["latestWithinWindow", "quorum", "twoPhase"]
        },
        "validatorPolicy": {
          "type": "object",
          "required": ["mode", "validators", "freshnessWindowHours"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["allowlist", "weightedAllowlist", "openButDownrank"]
            },
            "freshnessWindowHours": {"type": "number", "minimum": 0.1},
            "validators": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "validatorAddress",
                  "methodologyURI",
                  "scopeTags",
                  "weight",
                  "conflictRule"
                ],
                "properties": {
                  "validatorAddress": {
                    "type": "string",
                    "pattern": "^0x[a-fA-F0-9]{40}$"
                  },
                  "methodologyURI": {"type": "string", "format": "uri"},
                  "scopeTags": {
                    "type": "array",
                    "items": {"type": "string"},
                    "minItems": 1
                  },
                  "weight": {"type": "number", "minimum": 0},
                  "conflictRule": {
                    "type": "string",
                    "enum": ["preferHigherWeight", "preferQuorum", "markConflicted"]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "disclosures": {
      "type": "object",
      "required": [
        "integrityDefinition",
        "reputationPolicyDisclosure",
        "validatorDisclosure",
        "economicDependenciesDisclosure"
      ],
      "properties": {
        "integrityDefinition": {"type": "string"},
        "reputationPolicyDisclosure": {"type": "string"},
        "validatorDisclosure": {"type": "string"},
        "economicDependenciesDisclosure": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
